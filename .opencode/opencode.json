{
  "$schema": "https://opencode.ai/schema/config.json",
  "agents": {
    "testcase-leader": {
      "path": ".opencode/agents/testcase-leader.md",
      "description": "自动化测试用例生成编排 Agent。串联调度三个 Skill 完成从需求到代码的全流程。"
    }
  },
  "skills": {
    "testcase-refiner": {
      "path": ".opencode/skills/testcase-refiner/SKILL.md"
    },
    "testcase-planner": {
      "path": ".opencode/skills/testcase-planner/SKILL.md"
    },
    "testcase-coder": {
      "path": ".opencode/skills/testcase-coder/SKILL.md"
    }
  },
  "commands": {
    "gen-testcase": {
      "path": ".opencode/commands/gen-testcase.md",
      "description": "生成自动化测试用例。启动三阶段流水线：需求结构化 → 代码库分析 → 代码生成。"
    },
    "refine": {
      "path": ".opencode/commands/refine.md",
      "description": "只执行需求结构化阶段，将零散描述转为标准测试步骤。"
    },
    "plan": {
      "path": ".opencode/commands/plan.md",
      "description": "只执行代码库分析和生成计划阶段。"
    },
    "code": {
      "path": ".opencode/commands/code.md",
      "description": "只执行代码生成阶段，需提供已有的生成计划。"
    }
  }
}